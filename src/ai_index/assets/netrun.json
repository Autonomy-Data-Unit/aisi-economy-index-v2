{
  "extra": {
    "description": "AISI Economy Index v2 \u2014 AI exposure scoring pipeline. Matches job ads to O*NET occupations, computes multi-dimensional AI exposure scores, and aggregates results."
  },
  "node_vars": {
    "adzuna_s3_prefix": {
      "value": {
        "$env": "ADZUNA_S3_PREFIX",
        "default": "adu-project-data/aisi-economy-index/adzuna2025"
      },
      "type": "str"
    }
  },
  "storage": {
    "cache": {
      "enabled": true,
      "include_all_nodes": true,
      "storage_path": ".cache/netrun"

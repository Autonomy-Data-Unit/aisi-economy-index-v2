{
  "extra": {
    "description": "AISI Economy Index v2 \u2014 AI exposure scoring pipeline. Matches job ads to O*NET occupations, computes multi-dimensional AI exposure scores, and aggregates results."
  },
  "node_vars": {
    "adzuna_s3_prefix": {
      "value": {
        "$env": "ADZUNA_S3_PREFIX"
      },
      "type": "str"
    },
    "run_name": {
      "type": "str"
    },
    "sample_n": {
      "type": "int"
    },
    "sample_seed": {
      "type": "int"
    },
    "embedding_model": {
      "type": "str"
    },
    "llm_model": {
      "type": "str"
    },
    "cosine_mode": {
      "type": "str"
    },
    "topk": {
      "type": "int"
    }
  },
  "storage": {
    "cache": {
      "enabled": false,
      "include_all_nodes": true,
      "storage_path": ".cache/netrun"
    }
  },
  "max_epochs": 1,
  "project_root_override": "../",
  "graph": {
    "nodes": [
      {
        "name": "fetch_onet",
        "description": "Download and extract O*NET 30.0 database.",
        "execution_config": {
          "run_on_startup": true
        },
        "extra": {
          "ui": {
            "descriptionExpanded": false,
            "position": {
              "x": 12,
              "y": 12
            }
          }
        },
        "factory": "netrun.node_factories.from_function",
        "factory_args": {
          "func": "ai_index.nodes.fetch_onet.main"
        },
        "type": "node"
      },
      {
        "name": "fetch_adzuna",
        "description": "Download raw Adzuna job ads from S3, insert into DuckDB, and deduplicate by ID (earliest date_created wins).",
        "execution_config": {
          "run_on_startup": true,
          "node_vars": {
            "years": {
              "value": ""
            }
          },
          "signals": []
        },
        "extra": {
          "ui": {
            "descriptionExpanded": false,
            "position": {
              "x": 12,
              "y": 134
            }
          }
        },
        "factory": "netrun.node_factories.from_function",
        "factory_args": {
          "func": "ai_index.nodes.fetch_adzuna.main"
        },
        "type": "node"
      },
      {
        "name": "sample_ads",
        "description": "Sample job ads for processing (or pass through all if sample_n=0).",
        "extra": {
          "ui": {
            "position": {
              "x": 559,
              "y": 165
            }
          }
        },
        "factory": "netrun.node_factories.from_function",
        "factory_args": {
          "func": "ai_index.nodes.sample_ads.main"
        },
        "type": "node"
      }
    ],
    "edges": [
      {
        "source_str": "fetch_adzuna.adzuna_meta",
        "target_str": "sample_ads.adzuna_meta"
      }
    ],
    "extra": {
      "ui": {
        "interactionMode": "pan"
      }
    }
  }
}